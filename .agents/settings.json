{
	"permissions": {
		"allow": [
			"Bash(cd:*)",
			"Bash(ls:*)",
			"Bash(gh pr diff:*)",
			"Bash(gh pr view:*)",
			"Bash(git diff:*)",
			"Bash(git log:*)",
			"Bash(git show:*)",
			"Bash(git checkout:*)",
			"Bash(grep:*)",
			"Bash(head:*)",
			"Bash(cat:*)",
			"Bash(sed:*)",
			"Bash(find:*)",
			"Bash(rg:*)",
			"Bash(npm:*)",
			"Bash(node:*)",
			"WebFetch(domain:*)"
		]
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Read|Grep",
				"hooks": [
					{
						"type": "command",
						"command": "node ./.agents/hooks/read_hook.js"
					}
				]
			}
		]
	}
}
