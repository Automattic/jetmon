# Docker Compose reads this file for local development only.
# Port variables below are host-side bindings. Container-side service ports are
# hardcoded in docker-compose.yml so the containers can always reach each other
# at the same internal addresses.

# MySQL container bootstrap and Jetmon DB connection.
# MYSQL_USER is the account Jetmon uses; root is fine for local development.
MYSQL_USER=root
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=jetmon_db
MYSQL_PORT=3307

# Token used by Jetmon when generating local config/config.json from the sample.
WPCOM_AUTH_TOKEN=change_me

# Monitor-to-Veriflier auth plus host-side Veriflier status/check port.
VERIFLIER_AUTH_TOKEN=veriflier_1_auth_token
VERIFLIER_PORT=7803

# Host-side ports for the operator dashboard and internal REST API.
# These publish the hardcoded container ports to localhost. The API listener in
# config/config.json is a separate setting; Docker-generated config enables it
# on the container's hardcoded API port, 8090.
DASHBOARD_PORT=8080
API_PORT=8090

# Container user/group ids. Match these to your host user so bind-mounted files
# in config/, logs/, and stats/ stay writable without root-owned output.
UID=1000
GID=1000

# Local escape hatch for legacy config files that still contain
# DB_UPDATES_ENABLE. Do not enable this in staging or production.
# UNSAFE_DB_UPDATES=1
