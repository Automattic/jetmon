# Docker development defaults for Jetmon + Veriflier.
# Copy this file to .env and adjust only what you need locally.

# MySQL: MYSQLDB_USER uses root in local dev only.
# In staging/production, use a dedicated user with minimum required privileges.
MYSQLDB_USER=root
MYSQLDB_ROOT_PASSWORD=123456
MYSQLDB_DATABASE=jetmon_db
MYSQLDB_LOCAL_PORT=3307
MYSQLDB_DOCKER_PORT=3306

# WPCOM_JETMON_AUTH_TOKEN is only for Jetmon -> WPCOM API communication.
# API auth for /api/v1 is controlled only by JETMON_API_TOKENS.
# If JETMON_API_TOKENS is empty, /api/v1 auth is disabled for local dev.
WPCOM_JETMON_AUTH_TOKEN=change_me
JETMON_API_TOKENS=[]
JETMON_API_RATE_LIMIT_RPS=20
JETMON_API_RATE_LIMIT_BURST=40

VERIFLIER_AUTH_TOKEN=veriflier_1_auth_token
VERIFLIER_GRPC_LOCAL_PORT=7803
VERIFLIER_GRPC_DOCKER_PORT=7803

DASHBOARD_LOCAL_PORT=8080
DASHBOARD_DOCKER_PORT=8080

JETMON_UID=1000
JETMON_GID=1000

# Uncomment to allow DB_UPDATES_ENABLE in config.json (local dev only — never in production).
# JETMON_UNSAFE_DB_UPDATES=1
